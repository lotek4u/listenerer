# ===== Listenerer configuration =====
# Copy this file to ".env" next to the built executable and fill in values.
# All keys bind to AzureSettings via the AzureSettings__<Property> convention.

# --- Bot identity (from the Azure app registration) ---
AzureSettings__BotName=
AzureSettings__AadAppId=
AzureSettings__AadAppSecret=

# --- Public endpoint (you provide DNS + certificate) ---
AzureSettings__ServiceDnsName=
AzureSettings__CertificateThumbprint=

# --- Ports ---
# Signaling: HTTPS the Teams service calls (mapped to public 443 by default).
AzureSettings__CallSignalingPort=9441
# Public port Teams uses in the callback URL. Leave 443 unless your edge maps
# signaling to a non-standard public port.
AzureSettings__CallSignalingPublicPort=443
# Media: ONE TCP port receives all audio streams. A single media port multiplexes ALL
# concurrent calls on this instance -- you do NOT need a port per call. More media ports
# means more bot instances (pods); for the hackathon leave this as one.
AzureSettings__InstanceInternalPort=8445
AzureSettings__InstancePublicPort=

AzureSettings__PlaceCallEndpointUrl=https://graph.microsoft.com/v1.0

# --- Endpoint overrides (advanced; blank = sensible defaults) ---
# CNAME the media platform advertises; blank = ServiceDnsName.
AzureSettings__ServiceCname=
# URL path prefix for the signaling webhook; default "/" (webhook = /0/api/calling).
AzureSettings__ServicePath=

# --- Event Grid diagnostics (optional; inactive unless TopicKey is set) ---
AzureSettings__TopicName=recordingbotevents
AzureSettings__RegionName=australiaeast
AzureSettings__TopicKey=

# --- Recording output (Listenerer) ---
# Configurable sink: local dir or UNC share. Recordings land in <root>/<callId>/.
# Leave blank to default to the OS temp folder.
AzureSettings__RecordingRootFolder=D:\recordings

# --- Audio format ---
AzureSettings__IsStereo=false
AzureSettings__WAVSampleRate=
AzureSettings__WAVQuality=100

# --- Diagnostics / misc ---
AzureSettings__CaptureEvents=false
AzureSettings__PodName=bot-0
AzureSettings__MediaFolder=archive
AzureSettings__EventsFolder=events
